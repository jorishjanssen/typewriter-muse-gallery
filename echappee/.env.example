# LLM enrichment — leave all keys empty to run without AI (keyword categories,
# no summaries, title-based clustering).
#
# Preferred: Vercel AI Gateway — one key, switch models any time via LLM_MODEL.
AI_GATEWAY_API_KEY=
# LLM_MODEL=deepseek/deepseek-v3.1        # or anthropic/claude-haiku-4.5, openai/gpt-4o-mini, ...

# Alternative: a direct provider key (takes precedence over the gateway).
#   DeepSeek:  LLM_API_KEY=... (base URL/model default to DeepSeek)
#   OpenAI:    LLM_BASE_URL=https://api.openai.com/v1     LLM_MODEL=gpt-4o-mini
#   Local:     LLM_BASE_URL=http://localhost:11434/v1     LLM_MODEL=llama3.1
LLM_API_KEY=

# Scraper
SCRAPE_INTERVAL_MINUTES=30
SCRAPE_PER_HOST_DELAY_MS=2000

# Server
PORT=3600

# Storage: leave DATABASE_URL empty to use embedded PGlite (data/pg directory).
# Set it to any Postgres connection string (e.g. Neon) for hosted deployments.
# DATABASE_URL=postgres://user:pass@host/db
